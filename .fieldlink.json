{
  "fieldlink": {
    "atlas_repo": "https://github.com/JinnZ2/BioGrid2.0",
    "atlas_paths": [
      "planned/glyphs/atlas.json",
      "registry/atlas.glyphs.json"
    ],
    "local_manifests": [
      "glyphs/**",
      "protocols/**",
      "sensors/**",
      "atlas/shapes.json"
    ],
    "remote_mounts": {
      "symbolic-sensor-suite": {
        "repo": "https://github.com/JinnZ2/symbolic-sensor-suite",
        "mount": "atlas/remote/symbolic-sensor-suite/",
        "provides": ["sensors", "glyphs"]
      },
      "geo-binary-bridge": {
        "repo": "https://github.com/JinnZ2/geo-binary-bridge",
        "mount": "atlas/remote/geo-binary-bridge/",
        "provides": ["protocols", "shapes"]
      },
      "universal-redesign": {
        "repo": "https://github.com/JinnZ2/universal-redesign",
        "mount": "atlas/remote/universal-redesign/",
        "provides": ["protocols", "shapes"]
      }
    },
    "role": "sensors|protocols|shapes|hub",
    "sync": {
      "script": "fieldlink-pull.sh",
      "strategy": "shallow-clone",
      "note": "Run ./fieldlink-pull.sh to populate atlas/remote/ from declared mounts"
    }
  }
}
